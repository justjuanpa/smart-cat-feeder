# Public mobile app values. These are safe to expose in the Expo app.
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_KEY=your-publishable-key

# Backend-only value. Never put this in the mobile app or commit the real key.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Raspberry Pi / feeder device values. Keep the real token off mobile clients.
PAWS_INGEST_URL=https://your-project-ref.supabase.co/functions/v1/ingest-device
PAWS_DEVICE_SERIAL=PAWS-DEMO-001
PAWS_DEVICE_TOKEN=replace-with-the-plain-device-token-from-provisioning
