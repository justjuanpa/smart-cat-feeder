# Public mobile app values. These are safe to expose in the Expo app.
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_KEY=your-publishable-key

# Backend-only value. Never put this in the mobile app or commit the real key.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Shared secret used by the Raspberry Pi when calling the device ingestion API.
PAWS_DEVICE_INGEST_SECRET=replace-with-a-long-random-secret
