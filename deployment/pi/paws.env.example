# Copy this file to /etc/paws-feeder/paws.env on the Raspberry Pi.
# Keep the real file private. It contains the feeder device token.

REPO_DIR=/home/justjuanpa/Projects/smart-cat-feeder
VENV_DIR=/home/justjuanpa/Projects/smart-cat-feeder/.venv-torch-test

PAWS_INGEST_URL=https://chgzssjhocwuclarspwn.supabase.co/functions/v1/ingest-device
PAWS_DEVICE_SERIAL=PAWS-DEMO-001
PAWS_DEVICE_TOKEN=PASTE_THE_PLAIN_DEVICE_TOKEN_HERE

